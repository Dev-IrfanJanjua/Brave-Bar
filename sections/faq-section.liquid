{% style %}
  .section-{{ section.id }}{
      background: {{ section.settings.bg_color }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      position: relative;
  }

  .img-faq-question-before-icon {
    max-width: 32px;
    width: 100%;
    height: 32px;
}

.img-faqs-wrapper {
    display: flex;
    gap: 30px 40px;
    flex-wrap: wrap;
    position: relative;
}

.img-faqs-head {
    max-width: 100%;
    width: 100%;
    text-align: center;
}

.img-faqs-content,
.image-faqs-image-main {
    max-width: calc(50% - 20px);
    width: 100%;
    height: auto;
}

.img-faqs-content {
    display: flex;
    flex-direction: column;
    background: #FEF8EC;
    padding: 24px;
    gap: 24px;
    border-radius: 20px;
}

h2.img-faqs-title {
    margin: 0;
    font-family: Kefir Bold;
    font-weight: 700;
    font-size: 48px;
    line-height: 100%;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
    color: #152728;
}

h2.img-faqs-title em {
    color: #fff;
    font-style: normal;
}

.img-faqs-blocks {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.img-faq-answer {
    max-height: 0px;
    opacity: 0;
    transition: all 0.3s ease;
}

.img-faq-icon {
    max-width: 34px;
    width: 100%;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 0.3s ease;
    background: #D5792B;
    border-radius: 50%;
}

span.img-faq-icon-hr {
    display: block;
    height: 2px;
    width: 20px;
    background-color: #fff;
    position: absolute;
    top: 50%;
    transform: translatey(-50%);
    border-radius: 1px;
}

span.img-faq-icon-vt {
    display: block;
    height: 20px;
    width: 2px;
    background-color: #fff;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    transition: all 0.8s ease;
    opacity: 1;
}

.img-faq-question-inner {
    display: flex;
    align-items: center;
    gap: 16px;
}

.img-faq-question-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.5s ease;
}

.img-faq-item {
    padding: 18px;
    transition: all 0.3s ease;
    cursor: pointer;
    background: #D5792B1A;
    border-bottom: 2px solid #D5792B99;
    border-radius: 12px;
}

span.img-faq-question-text {
    color: #152728;
    transition: all 0.3s ease;
    font-family: Outfit;
    font-weight: 500;
    font-size: 24px;
    line-height: 100%;
    letter-spacing: 0;
}

.img-faq-answer * {
    color: #152728;
    font-family: Outfit;
    font-weight: 400;
    font-size: 20px;
    line-height: 30px;
    letter-spacing: 0;
    margin: 0;
}

.image-faqs-image-main img {
    border-radius: 12px;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.img-faq-item.active span.img-faq-icon-vt {
    transform: rotate(90deg);
    opacity: 0;
}

.img-faq-item.active .img-faq-question-wrapper {
    padding-bottom: 10px;
}

.img-faq-question-before-icon img {
    width: 100%;
    height: 100%;
    display: block;
}

  .section-{{ section.id }} .section_bg-image_top,
  .section-{{ section.id }} .section_bg-image_bottom {
      position: absolute;
      width: 100%;
      left: 0;
      right: 0;
      height: 80px;
  }

  .section-{{ section.id }} .section_bg-image_top{
    top: -4px; 
  }

  .section-{{ section.id }} .section_bg-image_bottom{
    bottom: -3px; 
  }

  .section-{{ section.id }} .section_bg-image_top img,
  .section-{{ section.id }} .section_bg-image_bottom img {
      width: 100%;
      height: 100% !important;
      object-fit: cover;
      display: block;
  }

  .img-faq-item.active .img-faq-icon {
    background: #fff;
}

.img-faq-item.active span.img-faq-icon-hr {
    background-color: #D5792B;
}

  @media screen and (max-width: 767px){
      .section-{{ section.id }}{
        padding-top: {{ section.settings.padding_top_mob }}px;
        padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }

    .img-faqs-content, .image-faqs-image-main {
        max-width: 100%;
    }

    .img-faqs-content {
    gap: 24px;
    padding: 12px;
}

    .img-faqs-blocks {
        gap: 10px;
    }

    .img-faq-item {
        padding: 12px;
    }

    .img-faq-question-before-icon {
        max-width: 24px;
        height: 24px;
    }

    span.img-faq-question-text {
    font-size: 16px;
    line-height: 22px;
}

.img-faq-item.active .img-faq-question-wrapper {
    padding-bottom: 4px;
}

.img-faq-answer * {
    font-size: 16px;
    line-height: 22px;
}

.image-faqs-image-main {
    aspect-ratio: 1;
}

    .img-faq-question-inner {
        gap: 8px;
    }

    .img-faqs-wrapper {
        gap: 24px;
    }

    h2.img-faqs-title {
    font-size: 28px;
    line-height: 32px;
}

.section-{{ section.id }} .section_bg-image_bottom {
    bottom: -2px;
    height: 30px;
}

.section-{{ section.id }} .section_bg-image_top {
    top: -3px;
    height: 30px;
}

  }
{% endstyle %}

<section class="img-faqs-section section-{{ section.id }}">
    {% if section.settings.bg_image_top != blank %}
      <div class="section_bg-image_top">
        {{ section.settings.bg_image_top | image_url: width: 1600 | image_tag:
            widths: '50, 100, 150, 200, 250, 300, 400, 500, 600, 1440',
            alt: 'image',
            loading: 'lazy'
        }}
      </div>
    {% endif %}

    {% if section.settings.bg_image_bottom != blank %}
      <div class="section_bg-image_bottom">
        {{ section.settings.bg_image_bottom | image_url: width: 1600 | image_tag:
            widths: '50, 100, 150, 200, 250, 300, 400, 500, 600, 1440',
            alt: 'image',
            loading: 'lazy'
        }}
      </div>
    {% endif %}
  <div class="page-width">


    <div class="img-faqs-wrapper">

        {% if section.settings.heading != blank %}
          <div class="img-faqs-head">
            <h2 class="img-faqs-title">{{ section.settings.heading }}</h2>
          </div>
        {% endif %}

      <!-- ===== Content ===== -->
      <div class="img-faqs-content">

        <div class="img-faqs-blocks">

          {%- liquid
            comment
              Decide source: metafields or blocks.
              use_metafields is true only when the checkbox is on
              AND the product has at least one question in the list.
            endcomment
            assign use_metafields = false
            if section.settings.use_metafields
              assign mf_questions = product.metafields.custom.pdp_accourdian_question.value
              assign mf_answers   = product.metafields.custom.pdp_accourdian_answer.value
              if mf_questions != blank
                assign use_metafields = true
              endif
            endif
          -%}

          {% if use_metafields %}

              {% for question in mf_questions %}
                {%- assign answer     = mf_answers[forloop.index0] -%}
                {%- assign block_icon = section.blocks[forloop.index0] -%}

                <div class="img-faq-item img-faq-item-{{ forloop.index }} {% if forloop.index == 3 %}active{% endif %}" >
                  {% if question != blank %}
                    <div class="img-faq-question-wrapper">
                      <div class="img-faq-question-inner">

                        {%- comment -%}
                          Use the icon from the matching block at the same index.
                          If that block exists and has an icon set, render it.
                          Falls back to nothing if no matching block or no icon.
                        {%- endcomment -%}
                        {% if block_icon != blank and block_icon.settings.question_icon_bf != blank %}
                          <div class="img-faq-question-before-icon">
                            {{
                              block_icon.settings.question_icon_bf
                              | image_url: width: 500
                              | image_tag:
                                widths: '50, 100, 150, 200, 250, 300, 400, 500',
                                alt: 'image',
                                loading: 'lazy'
                            }}
                          </div>
                        {% endif %}

                        <span class="img-faq-question-text">{{ question }}</span>
                      </div>
                      <div class="img-faq-icon">
                        <span class="img-faq-icon-hr"></span>
                        <span class="img-faq-icon-vt"></span>
                      </div>
                    </div>
                  {% endif %}

                  {% if answer != blank %}
                    <div class="img-faq-answer">
                      <p>{{ answer }}</p>
                    </div>
                  {% endif %}
                </div>

              {% endfor %}

            {% else %}

            {%- comment -%}
              Block source — original behaviour, unchanged.
            {%- endcomment -%}

            {% for block in section.blocks %}
              <div class="img-faq-item img-faq-item-{{ forloop.index }} {% if forloop.index == 3 %}active{% endif %} " {{ block.shopify_attributes }}>
                {% if block.settings.question != blank %}
                  <div class="img-faq-question-wrapper">
                    <div class="img-faq-question-inner">
                      {% if block.settings.question_icon_bf != blank %}
                        <div class="img-faq-question-before-icon">
                          {{
                            block.settings.question_icon_bf
                            | image_url: width: 500
                            | image_tag:
                              widths: '50, 100, 150, 200, 250, 300, 400, 500',
                              alt: 'image',
                              loading: 'lazy'
                          }}
                        </div>
                      {% endif %}
                      <span class="img-faq-question-text">{{ block.settings.question }}</span>
                    </div>
                    <div class="img-faq-icon">
                      <span class="img-faq-icon-hr"></span>
                      <span class="img-faq-icon-vt"></span>
                    </div>
                  </div>
                {% endif %}
                {% if block.settings.answer != blank %}
                  <div class="img-faq-answer">
                    {{ block.settings.answer }}
                  </div>
                {% endif %}
              </div>
            {% endfor %}

          {% endif %}

        </div>
      </div>

      <!-- ===== Image ===== -->
      {% if section.settings.use_metafields and product.metafields.custom.pdp_accourdian_image != blank %}
        <div class="image-faqs-image-main">
            {{
              product.metafields.custom.pdp_accourdian_image
              | image_url: width: 1000
              | image_tag:
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 600, 1440',
                alt: 'image',
                loading: 'lazy'
            }}
          </div>
      {% else %}
        {% if section.settings.image != blank %}
          <div class="image-faqs-image-main">
            {{
              section.settings.image
              | image_url: width: 1000
              | image_tag:
                widths: '50, 100, 150, 200, 250, 300, 400, 500, 600, 1440',
                alt: 'image',
                loading: 'lazy'
            }}
          </div>
        {% endif %}
      {% endif %}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    initImgFaqs();
  });

  document.addEventListener('shopify:section:load', () => {
    initImgFaqs();
  });

  function initImgFaqs() {
    const faqSections = document.querySelectorAll('.img-faqs-section');

    faqSections.forEach(section => {
      const faqItems = section.querySelectorAll('.img-faq-item');

      faqItems.forEach(item => {
        const question = item.querySelector('.img-faq-question-wrapper');
        const answer = item.querySelector('.img-faq-answer');

        if (!question || !answer) return;

        /* Respect active class already added in Liquid */
        if (item.classList.contains('active')) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.style.opacity = '1';
        } else {
          answer.style.maxHeight = null;
          answer.style.opacity = '0';
        }

        /* Prevent duplicate listeners on section reload */
        question.onclick = () => {
          const isActive = item.classList.contains('active');

          /* Close all items */
          faqItems.forEach(otherItem => {
            otherItem.classList.remove('active');

            const otherAnswer = otherItem.querySelector('.img-faq-answer');
            if (otherAnswer) {
              otherAnswer.style.maxHeight = null;
              otherAnswer.style.opacity = '0';
            }
          });

          /* Re-open clicked item only if it wasn't already active */
          if (!isActive) {
            item.classList.add('active');
            answer.style.maxHeight = answer.scrollHeight + 'px';
            answer.style.opacity = '1';
          }
        };
      });
    });
  }
</script>

{% schema %}
{
  "name": "Image FAQs",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_metafields",
      "label": "Use metafield FAQs",
      "info": "When enabled, questions and answers are pulled from the product metafields 'custom.pdp_accourdian_question' and 'custom.pdp_accourdian_answer' instead of the blocks below.",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image_top",
      "label": "Background Image Top"
    },
    {
      "type": "image_picker",
      "id": "bg_image_bottom",
      "label": "Background Image Bottom"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "label": "Padding Top Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "label": "Padding Bottom Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "question_icon_bf",
          "label": "Question Before Icon"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>You can return items within 30 days.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image FAQs",
      "category": "Custom",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}