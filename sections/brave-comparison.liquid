{% liquid
  assign section_bg = section.settings.section_bg
  assign left_bg = section.settings.left_bg
  assign right_bg = section.settings.right_bg
%}

{% style %}
  /* Desktop-first styles */
  .section-{{ section.id }} {
    background: {{ section_bg }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  .section-{{ section.id }} .brave-comparison__header {
    text-align: center;
    margin-bottom: 80px;
  }

  .section-{{ section.id }} .brave-comparison__heading {
    font-size: {{ section.settings.heading_size_desktop }}px;
    margin: 0;
    font-family: Kefir Bold;
    font-weight: 700;
    line-height: 100%;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color: #152728;
  }

  .section-{{ section.id }}  .brave-comparison__heading.inline-richtext em {
      font-style: normal;
      color: #D5792B;
  }

  .section-{{ section.id }} .brave-comparison__table {
    max-width: 768px;
    margin: 0 auto;
  }

  .section-{{ section.id }} .brave-comparison__headings,
  .section-{{ section.id }} .brave-comparison__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0px;
  }

  .section-{{ section.id }} .brave-comparison__headings {
    align-items: end;
  }

  .section-{{ section.id }} .brave-comparison__heading-col,
  .section-{{ section.id }} .brave-comparison__cell {
    position: relative;
  }

  .section-{{ section.id }} .brave-comparison__heading-col--left,
  .section-{{ section.id }} .brave-comparison__cell--left {
    background: {{ left_bg }};
  }

  .section-{{ section.id }} .brave-comparison__heading-col--right,
  .section-{{ section.id }} .brave-comparison__cell--right {
    background: {{ right_bg }};
    border-left: 1px solid #000;
  }

  .section-{{ section.id }} .brave-comparison__heading-col--right {
    min-height: 90px;
    border: 1px solid #000000;
    border-bottom: none;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .section-{{ section.id }} .brave-comparison__heading-col--left {
    min-height: 70px;
    border-width: 1px 0 0 1px;
    border-style: solid;
    border-color: #000000;
    border-top-left-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 12px;
  }

  .section-{{ section.id }} .brave-comparison__column-title {
    font-family: Outfit;
    font-weight: 600;
    font-size: 24px;
    line-height: 100%;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    color: #D5792B;
    margin: 0;
  }

  .section-{{ section.id }} .brave-comparison__heading-image {
    display: flex;
    justify-content: center;
    max-width: 150px;
    width: 100%;
    height: auto;
  }

  .section-{{ section.id }} .brave-comparison__heading-image-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .brave-comparison__rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .section-{{ section.id }} .brave-comparison__cell {
    min-height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-inline: 12px;
  }

  .section-{{ section.id }} .brave-comparison__cell-content {
    font-family: Outfit;
    font-weight: 500;
    font-size: 18px;
    line-height: 100%;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    margin: 0;
    max-width: 274px;
  }
  
  .section-{{ section.id }} .brave-comparison__cell.brave-comparison__cell--left .brave-comparison__cell-content {
        color: #152728;
   }

    .section-{{ section.id }} .brave-comparison__cell.brave-comparison__cell--right .brave-comparison__cell-content {
        color: #fff;
    }

  .section-{{ section.id }} .brave-comparison__row {
    border-left: 1px solid #000;
    border-right: 1px solid #000;
    border-top: 1px solid #47474780;
  }

  .section-{{ section.id }} .brave-comparison__row.brave-comparison__row--last {
      border-bottom: 1px solid #000;
      border-bottom-left-radius: 16px;
      border-bottom-right-radius: 16px;
      overflow: hidden;
  }

  .section-{{ section.id }} .brave-comparison__heading-col.brave-comparison__heading-col--right .brave-comparison__column-title {
      color: #fff;
  }

  .section-{{ section.id }} .brave-comparison__heading-image-absolute {
        max-width: 100px;
        width: 100%;
        height: auto;
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translate(-50%, -50%);
        display: none;
    }

    .section-{{ section.id }} .brave-comparison__heading-image-absolute img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

  /* Mobile overrides */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .section-{{ section.id }} .brave-comparison__header {
      margin-bottom: 60px;
    }

    .section-{{ section.id }} .brave-comparison__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    .section-{{ section.id }} .brave-comparison__column-title {
      font-size: 18px;
    }

    .section-{{ section.id }} .brave-comparison__heading-image {
      max-width: 80px;
      height: 34px;
    }

    .section-{{ section.id }} .brave-comparison__cell-content {
      font-size: 14px;
    }

    .section-{{ section.id }} .brave-comparison__heading-image-absolute {
        display: block;
    }

  }

{% endstyle %}

<section
  id="BraveComparison-{{ section.id }}"
  class="brave-comparison section-{{ section.id }}"
>
    <div class="page-width">
        <div class="brave-comparison__container">
            {% if section.settings.heading != blank %}
            <div class="brave-comparison__header">
                <{{ section.settings.heading_tag }} class="brave-comparison__heading inline-richtext">
                {{ section.settings.heading }}
                </{{ section.settings.heading_tag }}>
            </div>
            {% endif %}
    
            <div class="brave-comparison__table-wrapper">
            <div class="brave-comparison__table">
                <div class="brave-comparison__headings">
                <div class="brave-comparison__heading-col brave-comparison__heading-col--left">
                    {% if section.settings.heading_left != blank %}
                    <p class="brave-comparison__column-title inline-richtext">
                        {{ section.settings.heading_left }}
                    </p>
                    {% endif %}
                </div>
    
                <div class="brave-comparison__heading-col brave-comparison__heading-col--right">
                    {% if section.settings.heading_right_image != blank %}
                    <div class="brave-comparison__heading-image">
                        {{
                        section.settings.heading_right_image
                        | image_url: width: 500
                        | image_tag:
                            loading: 'lazy',
                            widths: '150, 250, 350, 500',
                            class: 'brave-comparison__heading-image-img'
                        }}
                    </div>
                    {% else %}
                      {% if section.settings.heading_right != blank %}
                      <p class="brave-comparison__column-title inline-richtext">
                          {{ section.settings.heading_right }}
                      </p>
                      {% endif %}
                    {% endif %}

                    {% if section.settings.heading_right_image_absolute != blank %}
                      <div class="brave-comparison__heading-image-absolute">
                          {{
                            section.settings.heading_right_image_absolute
                            | image_url: width: 500
                            | image_tag:
                                loading: 'lazy',
                                widths: '150, 250, 350, 500',
                                class: 'brave-comparison__heading-image-img_absolute'
                          }}
                      </div>
                    {% endif %}
    
                </div>
                </div>
    
                <div class="brave-comparison__rows">
                {% for block in section.blocks %}
                    <div
                    class="brave-comparison__row {% if forloop.last %}brave-comparison__row--last{% endif %}"
                    {{ block.shopify_attributes }}
                    >
                    <div class="brave-comparison__cell brave-comparison__cell--left">
                        {% if block.settings.left_content != blank %}
                        <p class="brave-comparison__cell-content inline-richtext">
                            {{ block.settings.left_content }}
                        </p>
                        {% endif %}
                    </div>
    
                    <div class="brave-comparison__cell brave-comparison__cell--right">
                        {% if block.settings.right_content != blank %}
                        <p class="brave-comparison__cell-content inline-richtext">
                            {{ block.settings.right_content }}
                        </p>
                        {% endif %}
                    </div>
                    </div>
                {% endfor %}
                </div>
            </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Brave Comparison",
  "class": "section brave-comparison-section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 30
    },
    {
      "type": "header",
      "content": "Table headings"
    },
    {
      "type": "text",
      "id": "heading_left",
      "label": "Left heading"
    },
    {
      "type": "text",
      "id": "heading_right",
      "label": "Right heading"
    },
    {
      "type": "image_picker",
      "id": "heading_right_image",
      "label": "Right heading image"
    },
    {
      "type": "image_picker",
      "id": "heading_right_image_absolute",
      "label": "Right heading image (absolute)"
    },
    {
      "type": "header",
      "content": "Background colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "left_bg",
      "label": "Left column background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "right_bg",
      "label": "Right column background",
      "default": "#2ea3db"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "left_content",
          "label": "Left content"
        },
        {
          "type": "text",
          "id": "right_content",
          "label": "Right content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brave Comparison",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
{% endschema %}