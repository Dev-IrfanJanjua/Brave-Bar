{% liquid
  assign section_id = section.id
  assign current_year = 'now' | date: '%Y'
%}

{% style %}
  .section-{{ section_id }} {
    background-color: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    position: relative;
    overflow: hidden;
  }

  .section-{{ section_id }} .page-width{
    position: relative;
  }

  .section-{{ section_id }} .brave-footer-top-shape {
    width: 100%;
    line-height: 0;
    position: absolute;
    top: -3px;
    z-index: 0;
    left: 0;
    right: 0;
    height: auto;
    bottom: auto;
  }

  .section-{{ section_id }} .brave-footer-top-shape img {
    width: 100%;
    height: 100%;
    display: block;
  }

    .section-{{ section_id }} .brave-footer-inner {
        display: flex;
        flex-direction: column;
        gap: 35px;
        position: relative;
        padding-top: 140px;
    }

  .section-{{ section_id }} .brave-footer-logo {
    display: flex;
    justify-content: center;
    max-width: 214px;
    width: 100%;
    margin: 0 auto;
    height: auto;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translatex(-50%);
    z-index: 2;
  }

  .section-{{ section_id }} .brave-footer-logo img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .section-{{ section_id }} .brave-footer-wrapper {
    display: flex;
    gap: 20px;
    align-items: start;
    justify-content: space-between;
  }

  .section-{{ section_id }} .brave-footer-menus {
    display: flex;
    gap: 20px;
    flex: 1;
  }

  .section-{{ section_id }} .brave-footer-menu {
    min-width: 180px;
  }

  .section-{{ section_id }} .brave-footer-menu-heading {
    margin: 0 0 20px;
    font-family: Outfit;
    font-weight: 500;
    font-size: 18px;
    line-height: 100%;
    letter-spacing: 0%;
    vertical-align: middle;
    text-align: start;
    color: #D5792B;
  }

  .section-{{ section_id }} .brave-footer-menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-{{ section_id }} .brave-footer-menu-list a.brave-footer-menu-list-item_link {
    text-decoration: none;
    color: #D5792B;
    font-family: Outfit;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0;
    vertical-align: middle;
    transition: all 0.3s ease;
    position: relative;
    display: inline-block;
  }

  .section-{{ section_id }} .brave-footer-menu-list a.brave-footer-menu-list-item_link::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -2px;
        width: 100%;
        height: 1px;
        background-color: currentColor;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s ease;
    }

    .section-{{ section_id }} .brave-footer-menu-list a.brave-footer-menu-list-item_link:hover::after {
        transform: scaleX(1);
        transform-origin: left;
    }

    .section-{{ section_id }} .brave-footer-menu-list a.brave-footer-menu-list-item_link:not(:hover)::after {
        transform-origin: right;
    }

  .section-{{ section_id }} .brave-footer-menus.brave-footer-menus--right {
        justify-content: end;
    }

  .section-{{ section_id }} .brave-footer-newsletter {
    max-width: fit-content;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .section-{{ section_id }} .brave-footer-newsletter-heading{
    font-family: Outfit;
    font-weight: 400;
    font-size: 16px;
    line-height: 22px;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    color: #D5792B;
    margin: 0;
  }

  .section-{{ section_id }} .brave-footer-newsletter-desc {
    margin: 0 0 20px;
    color: #152728;
  }

  .section-{{ section_id }} .brave-footer-newsletter .klaviyo-form,
  .section-{{ section_id }} .brave-footer-newsletter form {
    width: 100%;
  }

  .section-{{ section_id }} .brave-footer-bottom {
    padding-top: 10px;
    display: none;
  }

  .section-{{ section_id }} .brave-footer-socials {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
  }

  .section-{{ section_id }} .brave-footer-social {
    display: flex;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .section-{{ section_id }} .brave-footer-social:hover{
    transform: scale(1.1);
  }

  .section-{{ section_id }} .brave-footer-social img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section_id }} .brave-footer-copyright {
    margin: 0 auto;
    color: #D5792B;
    font-family: Outfit;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    max-width: 145px;
  }

  .section-{{ section_id }} .brave-footer-copyright a {
    color: #D5792B;
    font-family: Outfit;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0;
    text-align: center;
    text-decoration: none;
  }

  .section-{{ section_id }} .brave-footer-accordion-icon {
    display: none;
  }

  .section-{{ section_id }} .brave-footer-newsletter-field {
        position: relative;
    }

    .section-{{ section_id }} input.brave-footer-newsletter-input {
        width: 100%;
        max-width: 100%;
        border: 1px solid #2C2609;
        border-radius: 8px;
        padding: 15px 16px;
        font-family: Outfit;
        font-weight: 400;
        font-size: 13.45px;
        line-height: 100%;
        letter-spacing: 0.4px;
        vertical-align: middle;
        color: #D5792BBF;
        outline: none;
        box-shadow: none;
    }

    .section-{{ section_id }} button.brave-footer-newsletter-btn {
        border: none;
        background: transparent;
        outline: none;
        box-shadow: none;
        width: 25px;
        height: 25px;
        display: flex;
        padding: 0;
        position: absolute;
        top: 50%;
        right: 13px;
        transform: translatey(-50%);
        cursor: pointer;
        z-index: 2;
    }

    .section-{{ section_id }} button.brave-footer-newsletter-btn svg {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .section-{{ section_id }} p.brave-footer-newsletter-success {
        font-family: Outfit;
        font-weight: 400;
        font-size: 16px;
        line-height: 20px;
        letter-spacing: 0;
        text-align: center;
        vertical-align: middle;
        color: green;
        margin: 10px 0 0;
    }

    .section-{{ section_id }} .brave-footer-newsletter-input::-webkit-input-placeholder {
    color: #D5792B;
    }

    .section-{{ section_id }} .brave-footer-newsletter-input::-moz-placeholder {
    color: #D5792B;
    }

    .section-{{ section_id }} .brave-footer-newsletter-input:-ms-input-placeholder {
    color: #D5792B;
    }

    .section-{{ section_id }} .brave-footer-newsletter-input::-ms-input-placeholder {
    color: #D5792B;
    }

  @media screen and (max-width: 768px) {
    .section-{{ section_id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .section-{{ section_id }} .brave-footer-top-shape {
        top: 0px;
    }

    .section-{{ section_id }} .brave-footer-top-shape--desktop {
      display: none;
    }

    .section-{{ section_id }} .brave-footer-inner {
        gap: 30px;
        padding-top: 100px;
    }

    .section-{{ section_id }} .brave-footer-logo {
        max-width: 149px;
    }


    .section-{{ section_id }} .brave-footer-wrapper {
        gap: 30px;
        flex-direction: column;
    }

    .section-{{ section_id }} .brave-footer-menus {
        flex-direction: column;
        gap: 30px;
        order: 2;
        max-width: 100%;
        width: 100%;
    }

    .section-{{ section_id }} .brave-footer-menu-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        width: 100%;
        padding-bottom: 8px;
        border-bottom: 1px solid #D5792B66;
        transition: all 0.3s ease;
    }

    .section-{{ section_id }} .brave-footer-accordion-icon {
        display: flex;
        transition: all .3s ease;
        background: #D5792B;
        width: 17px;
        height: 17px;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        text-align: center;
        padding: 3px;
    }

    .section-{{ section_id }} .brave-footer-accordion-icon_icon {
        width: 11px;
        height: 11px;
        flex-shrink: 0;
        display: block;
    }

    .section-{{ section_id }} .brave-footer-accordion-icon_icon svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .section-{{ section_id }} .brave-footer-menu.is-open span.brave-footer-accordion-icon_plus.brave-footer-accordion-icon_icon {
        display: none;
    }

    .section-{{ section_id }} .brave-footer-menu.is-open span.brave-footer-accordion-icon_minus.brave-footer-accordion-icon_icon {
        display: block !important;
    }

    .section-{{ section_id }} .brave-footer-menu.is-open .brave-footer-accordion-icon {
      transform: rotate(180deg);
    }

    .section-{{ section_id }} .brave-footer-menu-list {
      max-height: 0;
      overflow: hidden;
      transition: max-height .3s ease;
      gap: 0;
    }

    .section-{{ section_id }} .brave-footer-newsletter {
        order: 1;
        max-width: 100%;
        gap: 12px;
    }

    .section-{{ section_id }} .brave-footer-menu.is-open .brave-footer-menu-trigger {
        margin-bottom: 20px;
    }

    .section-{{ section_id }} .brave-footer-newsletter-heading {
        font-size: 14px;
        line-height: 20px;
    }

    .section-{{ section_id }} .brave-footer-menu-heading {
        margin: 0;
    }

    .section-{{ section_id }} .brave-footer-social {
        width: 36px;
        height: 36px;
    }

    .section-{{ section_id }} .brave-footer-bottom {
      display: block;
    }

    .section-{{ section_id }} .brave-footer-socials {
      order: 1;
      gap: 12px;
    }

    .section-{{ section_id }} p.brave-footer-copyright.brave-footer-copyright_desk {
        display: none;
    }

    .section-{{ section_id }} .brave-footer-copyright {
        max-width: 100%;
    }


  }

  @media screen and (min-width: 769px) {
    .section-{{ section_id }} .brave-footer-top-shape--mobile {
      display: none;
    }
  }
{% endstyle %}

<section class="brave-footer-section section-{{ section_id }}">
  {% if section.settings.top_svg_desktop != blank %}
    <div class="brave-footer-top-shape brave-footer-top-shape--desktop">
      {{ section.settings.top_svg_desktop | image_url: width: 2000 | image_tag: loading: 'lazy', alt: 'Footer shape' }}
    </div>
  {% endif %}

  {% if section.settings.top_svg_mobile != blank %}
    <div class="brave-footer-top-shape brave-footer-top-shape--mobile">
      {{ section.settings.top_svg_mobile | image_url: width: 1000 | image_tag: loading: 'lazy', alt: 'Footer shape' }}
    </div>
  {% endif %}

  <div class="page-width">

    <div class="brave-footer-inner">
        {% if section.settings.logo != blank %}
          <a href="{{ routes.root_url }}" class="brave-footer-logo">
            {{ section.settings.logo | image_url: width: 400 | image_tag: loading: 'lazy', alt: shop.name }}
          </a>
        {% endif %}
    
        <div class="brave-footer-wrapper">
          <div class="brave-footer-menus brave-footer-menus--left">
            {% for block in section.blocks %}
              {% if block.type == 'menu' and block.settings.position == 'left' and block.settings.menu != blank %}
                <div class="brave-footer-menu" {{ block.shopify_attributes }}>
                  <div class="brave-footer-menu-trigger">
                    {% if block.settings.heading != blank %}
                      <h3 class="brave-footer-menu-heading">{{ block.settings.heading }}</h3>
                    {% endif %}
                    <div class="brave-footer-accordion-icon">
                        <span class="brave-footer-accordion-icon_plus brave-footer-accordion-icon_icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 20 20" fill="none">
                                <path d="M3 10H17" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                <path d="M10 3V17" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </span>
                        <span class="brave-footer-accordion-icon_minus brave-footer-accordion-icon_icon" style="display: none;">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M1.64844 5.5H9.34844" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </div>
                  </div>
    
                  <ul class="brave-footer-menu-list">
                    {% for link in block.settings.menu.links %}
                      <li class="brave-footer-menu-list-item"><a class="brave-footer-menu-list-item_link" href="{{ link.url }}">{{ link.title }}</a></li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            {% endfor %}
          </div>
    
          <div class="brave-footer-newsletter">
            {% if section.settings.newsletter_heading != blank %}
              <h3 class="brave-footer-newsletter-heading">{{ section.settings.newsletter_heading }}</h3>
            {% endif %}
    
            {% if section.settings.newsletter_desc != blank %}
              <p class="brave-footer-newsletter-desc">{{ section.settings.newsletter_desc }}</p>
            {% endif %}
    
            {% form 'customer', class: 'brave-footer-newsletter-form' %}
                <div class="brave-footer-newsletter-field">
                    <input type="hidden" name="contact[tags]" value="newsletter">
    
                    <input
                    type="email"
                    name="contact[email]"
                    class="brave-footer-newsletter-input"
                    value="{% if form.email %}{{ form.email }}{% endif %}"
                    placeholder="Get on the list!"
                    autocorrect="off"
                    autocapitalize="off"
                    required
                    >
    
                    <button type="submit" class="brave-footer-newsletter-btn">
                        <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clip-path="url(#clip0_721_4684)">
                            <rect width="25" height="25" rx="12.5" fill="#D5792B"/>
                            <path d="M10 17.5352L15 12.0352L10 6.53516" stroke="white" stroke-width="2.15625" stroke-linecap="round" stroke-linejoin="round"/>
                            </g>
                            <defs>
                            <clipPath id="clip0_721_4684">
                            <rect width="25" height="25" rx="12.5" fill="white"/>
                            </clipPath>
                            </defs>
                        </svg>
                    </button>
                </div>
    
                {% if form.posted_successfully? %}
                    <p class="brave-footer-newsletter-success"> Thanks for subscribing! </p>
                {% endif %}
    
                {% if form.errors %}
                    <div class="brave-footer-newsletter-errors">
                    {{ form.errors | default_errors }}
                    </div>
                {% endif %}
            {% endform %}
    
            <div class="brave-footer-socials">
                {% for block in section.blocks %}
                {% if block.type == 'social' and block.settings.icon != blank and block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="brave-footer-social" {{ block.shopify_attributes }}>
                    {{ block.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy', alt: 'Social icon' }}
                    </a>
                {% endif %}
                {% endfor %}
            </div>
    
            {% if section.settings.copyright_text != blank %}
                <p class="brave-footer-copyright brave-footer-copyright_desk">@ {{ current_year }} {{ section.settings.copyright_text | replace: '<p>', '' | replace: '</p>', '' }}</p>
            {% endif %}
    
          </div>
    
          <div class="brave-footer-menus brave-footer-menus--right">
            {% for block in section.blocks %}
              {% if block.type == 'menu' and block.settings.position == 'right' and block.settings.menu != blank %}
                <div class="brave-footer-menu" {{ block.shopify_attributes }}>
                  <div class="brave-footer-menu-trigger">
                    {% if block.settings.heading != blank %}
                      <h3 class="brave-footer-menu-heading">{{ block.settings.heading }}</h3>
                    {% endif %}
                    <div class="brave-footer-accordion-icon">
                        <span class="brave-footer-accordion-icon_plus brave-footer-accordion-icon_icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 20 20" fill="none">
                                <path d="M3 10H17" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                <path d="M10 3V17" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </span>
                        <span class="brave-footer-accordion-icon_minus brave-footer-accordion-icon_icon" style="display: none;">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M1.64844 5.5H9.34844" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </div>
                  </div>
    
                  <ul class="brave-footer-menu-list">
                    {% for link in block.settings.menu.links %}
                      <li class="brave-footer-menu-list-item"><a class="brave-footer-menu-list-item_link" href="{{ link.url }}">{{ link.title }}</a></li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
    
        <div class="brave-footer-bottom">
            {% if section.settings.copyright_text != blank %}
                <p class="brave-footer-copyright brave-footer-copyright_mob">@ {{ current_year }} {{ section.settings.copyright_text | replace: '<p>', '' | replace: '</p>', '' }}</p>
            {% endif %}
        </div>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.innerWidth > 768) return;

    const section = document.querySelector('.section-{{ section_id }}');

    if (!section) return;

    const menuItems = section.querySelectorAll('.brave-footer-menu');

    function closeMenu(menu) {
      const content = menu.querySelector('.brave-footer-menu-list');

      menu.classList.remove('is-open');
      content.style.maxHeight = null;
    }

    function openMenu(menu) {
      const content = menu.querySelector('.brave-footer-menu-list');

      menu.classList.add('is-open');
      content.style.maxHeight = content.scrollHeight + 'px';
    }

    menuItems.forEach((menu, index) => {
      const trigger = menu.querySelector('.brave-footer-menu-trigger');
      const content = menu.querySelector('.brave-footer-menu-list');

      content.style.overflow = 'hidden';
      content.style.transition = 'max-height 0.35s ease';

      if (index === 0) {
        openMenu(menu);
      }

      trigger.addEventListener('click', function () {
        const isOpen = menu.classList.contains('is-open');

        menuItems.forEach((item) => {
          closeMenu(item);
        });

        if (!isOpen) {
          openMenu(menu);
        }
      });
    });

    window.addEventListener('resize', function () {
      menuItems.forEach((menu) => {
        if (menu.classList.contains('is-open')) {
          const content = menu.querySelector('.brave-footer-menu-list');
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Brave Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "top_svg_desktop",
      "label": "Top SVG desktop"
    },
    {
      "type": "image_picker",
      "id": "top_svg_mobile",
      "label": "Top SVG mobile"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background color",
      "default": "#F6F2EA"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_desc",
      "label": "Newsletter description"
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "<p>Your Store. All rights reserved.</p>"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brave Footer",
      "category": "Brave"
    }
  ]
}
{% endschema %}