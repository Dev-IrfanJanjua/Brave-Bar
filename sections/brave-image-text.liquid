{% liquid
  assign section_id = section.id
%}

{% style %}
.section-{{ section_id }} {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  background-color: {{ section.settings.section_bg }};
}

.section-{{ section_id }} .brave-img-text-wrapper {
    background-color: {{ section.settings.wrapper_bg }};
    border: {{ section.settings.wrapper_border_width }}px solid {{ section.settings.wrapper_border_color }};
    display: flex;
    align-items: center;
    gap: 40px;
}

.brave-img-text-content {
    max-width: calc(50% - 20px);
    width: 100%;
}

.section-{{ section_id }} .brave-img-text-title {
  font-family: Kefir Bold;
  font-weight: 700;
  font-size: 36px;
  line-height: 46px;
  color: #152728;
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0;
}

.section-{{ section_id }} .brave-img-text-title.inline-richtext em {
  color: #D5792B;
  font-style: normal;
}

.section-{{ section_id }} .brave-img-text-desc {
  font-family: Outfit;
  font-weight: 400;
  font-size: 18px;
  line-height: 24px;
  color: #152728;
  margin: 30px 0 0;
}

a.brave-img-text-btn.btn_btn {
    margin-top: 40px;
}

.brave-img-text-image {
    max-width: calc(50% - 20px);
    width: 100%;
    height: auto;
}

.brave-img-text-image img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
}

@media screen and (max-width: 768px) {
  .section-{{ section_id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  .section-{{ section_id }} .brave-img-text-wrapper {
    flex-direction: column;
    gap: 24px;
  }

  .brave-img-text-content,
  .brave-img-text-image {
        max-width: 100%;
    }

  .section-{{ section_id }} .brave-img-text-title {
    font-size: 28px;
    line-height: 32px;
    text-align: center;
  }

  .section-template--18693906464839__brave_image_text_VXrygQ .brave-img-text-desc {
        font-size: 16px;
        line-height: 22px;
        margin: 16px 0 0;
    }

    a.brave-img-text-btn.btn_btn {
        margin-top: 20px;
        display: flex;
        max-width: fit-content;
        margin-inline: auto;
    }

}
{% endstyle %}

<section class="brave-img-text-section section-{{ section_id }}">
  <div class="page-width">
    <div class="brave-img-text-wrapper">
      {% if section.settings.title != blank or section.settings.desc != blank %}
      <div class="brave-img-text-content">
        <div class="brave-img-text-head">
          {% if section.settings.title != blank %}
          <h2 class="brave-img-text-title inline-richtext">{{ section.settings.title }}</h2>
          {% endif %}
          {% if section.settings.desc != blank %}
          <p class="brave-img-text-desc">{{ section.settings.desc }}</p>
          {% endif %}
        </div>
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
        <a href="{{ section.settings.btn_link }}" class="brave-img-text-btn btn_btn">{{ section.settings.btn_text }}</a>
        {% endif %}
      </div>
      {% endif %}

      {% if section.settings.image != blank %}
      <div class="brave-img-text-image">
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', alt: 'image' }}
      </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brave Image & Text",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Your <em>section</em> title"
    },
    {
      "type": "textarea",
      "id": "desc",
      "label": "Description",
      "default": "Add your description here"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Select an image"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "wrapper_bg",
      "label": "Wrapper background color",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "wrapper_border_color",
      "label": "Wrapper border color",
      "default": "#d9d9d9"
    },
    {
      "type": "range",
      "id": "wrapper_border_width",
      "label": "Wrapper border width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Brave Image & Text",
      "category": "Brave"
    }
  ]
}
{% endschema %}