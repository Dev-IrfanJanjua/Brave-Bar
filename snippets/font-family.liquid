{% style %}

/* ======== Kafir Fonts ====== */

@font-face {
    font-family: 'Kefir Bold';
    src: url({{ 'Kefir-Bold.woff2' | file_url }}) format('woff2'),
         url({{ 'Kefir-Bold.woff' | file_url }}) format('woff');
    font-weight: bold;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'Kefir DemiBold';
    src: url({{ 'Kefir-DemiBold.woff2' | file_url }}) format('woff2'),
         url({{ 'Kefir-DemiBold.woff' | file_url }}) format('woff');
    font-weight: 600;
    font-style: normal;
    font-display: swap;
}

